+import '../models/movie.dart';
+import '../services/tmdb_service.dart';
+
+/// TMDB helpers matching PlayTorrio V2 naming (used by live TV catalog).
+class TmdbApi {
+  static String getImageUrl(String path) {
+    if (path.isEmpty) return '';
+    if (path.startsWith('http')) return path;
+    return 'https://image.tmdb.org/t/p/w500$path';
+  }
+
+  static String getBackdropUrl(String path) {
+    if (path.isEmpty) return '';
+    if (path.startsWith('http')) return path;
+    return 'https://image.tmdb.org/t/p/w1280$path';
+  }
+
+  Future<Movie?> findByImdbId(String imdbId, {required String mediaType}) async {
+    final m = await TmdbService.findByImdbId(
+      imdbId,
+      mediaType: mediaType == 'tv' ? 'tv' : 'movie',
+    );
+    if (m == null) return null;
+    return Movie.fromJson(m, mediaType: m['media_type'] as String?);
+  }
+
+  Future<List<Movie>> searchMulti(String query) async {
+    final raw = await TmdbService.searchMulti(query);
+    final out = <Movie>[];
+    for (final e in raw) {
+      if (e is! Map<String, dynamic>) continue;
+      final mt = e['media_type'] as String?;
+      if (mt != 'movie' && mt != 'tv') continue;
+      out.add(Movie.fromJson(e, mediaType: mt));
+    }
+    return out;
+  }
+}
